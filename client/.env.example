# Client environment example
# Copy to client/.env and adjust for local or Docker/nginx usage.

# Socket.IO base URL and REST endpoints for local Vite development.
# For nginx/prod-style same-origin builds, these can be relative paths.
VITE_API_URL=http://localhost:3000
VITE_API_URL_AUTH=http://localhost:3000/api/auth
VITE_API_URL_USERS=http://localhost:3000/api/users
VITE_API_URL_MESSAGES=http://localhost:3000/api/messages
VITE_API_URL_GROUPS=http://localhost:3000/api/groups
VITE_API_URL_FILES=http://localhost:3000/api/files
VITE_API_URL_CALLS=http://localhost:3000/api/calls

# Vite dev proxy target, used by client/vite.config.js.
VITE_PROXY_TARGET=http://localhost:3000

VITE_DEFAULT_AVATAR=https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y

# Notes:
# - Firebase web config is currently hardcoded in client/src/services/firebase/firebaseClient.js.
# - Server Firebase Admin uses server/src/config/firebase-service.json.
# - Optional TURN variables are not currently consumed by client code.
