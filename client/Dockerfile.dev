FROM node:22-alpine

WORKDIR /app

# Install dependencies trước để tận dụng Docker layer cache
COPY package*.json ./
RUN npm install

COPY . .

# Chạy Vite dev server với hot-reload
# --host 0.0.0.0: phát sóng ra toàn mạng để máy host truy cập được
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
