PORT=3000
MONGO_URI=mongodb://localhost:27017/shot-chat
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

EMAIL_USER=your-email@example.com
EMAIL_PASS=replace-with-email-app-password

URL_FRONTEND=http://localhost:5173
DEFAULT_AVATAR=https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_S3_BUCKET_NAME=replace-with-s3-bucket-name
CLOUDFRONT_URL=https://example.cloudfront.net

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_URL=amqp://replace-with-user:replace-with-password@localhost:5672
RABBITMQ_USER=replace-with-rabbitmq-user
RABBITMQ_PASS=replace-with-rabbitmq-password

NODE_NAME=backend
NODE_ENV=development
