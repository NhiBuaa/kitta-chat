# Server / worker environment example
# Copy to server/.env and replace placeholder values. Do not commit real secrets.

# Runtime
NODE_ENV=development
NODE_NAME=backend
PORT=3000
# Frontend origin for password reset links and CORS/socket origins.
# Use http://localhost:5173 for Vite dev.
# Use http://localhost for Docker/nginx demo.
URL_FRONTEND=http://localhost:5173
DEFAULT_AVATAR=https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y

# MongoDB canonical database
# Required by backend and image-worker. Docker Compose injects mongodb://mongo:27017/shot-chat for them.
MONGO_URI=mongodb://localhost:27017/shot-chat

# JWT used by REST auth and Socket.IO auth
# Required by backend.
JWT_SECRET=replace-with-a-long-random-secret

# Optional separate signing secret for HttpOnly refresh/session cookies.
# If omitted, JWT_SECRET is reused to preserve local developer workflow.
REFRESH_TOKEN_SECRET=replace-with-a-second-long-random-secret
# In production, refresh cookies are Secure by default. Set false only for controlled non-HTTPS testing.
AUTH_COOKIE_SECURE=false

# Redis cache/presence/Socket.IO adapter/call coordination
# Required by backend and image-worker. Use REDIS_URL when possible; REDIS_HOST/REDIS_PORT are fallback.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ background jobs only
# Required by RabbitMQ workers.
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_MAX_ATTEMPTS=3
RABBITMQ_RETRY_DELAY_MS=30000
RABBITMQ_WORKER_RECONNECT_DELAY_MS=1000
RABBITMQ_WORKER_MAX_RECONNECT_DELAY_MS=30000
IMAGE_WORKER_CONCURRENCY=2
NOTIFICATION_WORKER_CONCURRENCY=5
AUDIT_WORKER_CONCURRENCY=10

# Call hardening feature flags
# Disabled by default; local activeTimeouts remain enabled as fallback.
CALL_DISTRIBUTED_TIMEOUT_ENABLED=false
CALL_DISTRIBUTED_TIMEOUT_POLL_MS=1000

# Email / notification worker
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@example.com
EMAIL_PASS=replace-with-email-app-password

# Firebase Admin / Google login
# Google login requires server/src/config/firebase-service.json.
# Do not commit firebase-service.json; it is intentionally ignored by git.

# AWS S3 / CloudFront-compatible file delivery
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_S3_BUCKET_NAME=replace-with-s3-bucket-name
CLOUDFRONT_URL=https://example.cloudfront.net
